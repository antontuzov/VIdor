# Vidor Backend Configuration
# Copy this file to .env and fill in your values

# Backend server
BACKEND_URL=http://localhost:8080

# Qwen Audio API (for AI transcription and TTS)
# Get your key from: https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key_here

# TURN/STUN Server for WebRTC NAT traversal
# Use coturn (included in docker-compose) or a public STUN server
TURN_SERVER=turn:localhost:3478
TURN_USERNAME=vidor
TURN_PASSWORD=your_turn_password_here

# JWT Secret for token signing
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Database (PostgreSQL)
DATABASE_URL=postgresql://vidor:vidor_password@localhost:5432/vidor

# Optional: Local Whisper model path (if not using Qwen API)
WHISPER_MODEL_PATH=

# Logging level
LOG_LEVEL=info
